<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/admin_white_container"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <!-- Left Side: Text Group -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/quiz_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email"
            android:textSize="15sp"
            android:textColor="@color/dark_green"
            android:textStyle="bold" />

        <!-- Changed from TextView to ImageView -->
        <ImageView
            android:id="@+id/admin_view_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/admin_view_details_button"
            android:contentDescription="View Details"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Right Side: Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Changed from TextView to ImageView -->
        <ImageView
            android:id="@+id/admin_approve_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:contentDescription="Approve"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/admin_approve_button"
            tools:ignore="TouchTargetSizeCheck" />

        <!-- Changed from TextView to ImageView -->
        <ImageView
            android:id="@+id/admin_reject_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:contentDescription="Reject"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/admin_reject_button"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>
</LinearLayout>